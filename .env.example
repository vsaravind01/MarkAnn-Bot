# Copy this file to .env and fill in the values.
# .env is gitignored — never commit real secrets.

# ── Auth (required) ───────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=change-me-generate-a-real-secret

# ── LLM (required for the engine) ────────────────────────────────────────
# Choose one provider and supply the matching key.
LLM_PROVIDER=gemini          # gemini | openai | anthropic

GEMINI_API_KEY=
GEMINI_MODEL=gemma-4-31b-it    # optional — overrides the default model
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# ── Engine tuning (optional) ──────────────────────────────────────────────
POLL_INTERVAL=5              # seconds between NSE polls
